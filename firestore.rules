rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /suppliers/{supplierId} {
      allow read, write: if isAuthenticated();
    }

    match /purchaseOrders/{orderId} {
      allow read, write: if isAuthenticated();
    }
  }
}
